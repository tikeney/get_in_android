<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Get_In" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary Brand Color -->
        <item name="colorPrimary">@color/brand_blue</item>
        <item name="colorOnPrimary">@color/pure_white</item>
        <item name="colorPrimaryContainer">@color/brand_blue_light</item>
        <item name="colorOnPrimaryContainer">@color/pure_white</item>

        <!-- Secondary / Accent -->
        <item name="colorSecondary">@color/brand_blue_light</item>
        <item name="colorOnSecondary">@color/pure_white</item>

        <!-- Background and Surfaces -->
        <item name="android:windowBackground">@color/light_bg</item>
        <item name="colorSurface">@color/light_surface</item>
        <item name="colorOnSurface">@color/light_text_primary</item>
        <item name="colorOnSurfaceVariant">@color/light_text_secondary</item>
        <item name="colorOutline">@color/light_divider</item>

        <!-- Status Bar & Navigation Bar -->
        <item name="android:statusBarColor">@color/brand_blue</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.Get_In" parent="Base.Theme.Get_In" />
</resources>
