<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:id="@+id/containerCheckIn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingBottom="100dp"
            android:clipToPadding="false">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/tituloDadosPessoaisForms"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginBottom="15dp"
                        >

                        <ImageView
                            android:id="@+id/iconDadosPessoaisForms"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/outline_person_24"
                            android:scaleType="centerCrop"
                            android:clipToOutline="true"
                            android:background="@drawable/bg_icon"
                            android:backgroundTint="?attr/colorIconBackground"
                            android:padding="8dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />

                        <TextView
                            android:id="@+id/txtDadosPessoaisForms"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginStart="16dp"
                            android:text="Dados Pessoais"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="25sp"
                            android:gravity="center_vertical"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/iconDadosPessoaisForms"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"/>


                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorSurfaceVariant"
                        android:layout_marginBottom="24dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/tituloDadosPessoaisForms" />


                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/inputNome"
                        style="@style/Widget.Material3.TextInputLayout.FilledBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="15dp"
                        android:hint="Nome Completo"
                        app:boxBackgroundColor="?attr/colorSurfaceVariant"
                        app:boxStrokeWidth="0dp"
                        app:boxStrokeWidthFocused="0dp"
                        app:startIconTint="?attr/colorOnSurfaceVariant">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etNome"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="?attr/colorOnSurface"
                            android:background="@drawable/bg_tag_status"
                            android:inputType="textPersonName" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:baselineAligned="false">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/inputCPF"
                            style="@style/Widget.Material3.TextInputLayout.FilledBox"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:layout_marginBottom="15dp"
                            android:hint="CPF"
                            app:boxBackgroundColor="?attr/colorSurfaceVariant"
                            app:boxStrokeWidth="0dp"
                            app:boxStrokeWidthFocused="0dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etCPF"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="?attr/colorOnSurface"
                                android:background="@drawable/bg_tag_status"
                                android:backgroundTint="?attr/colorSurfaceVariant"
                                android:inputType="number" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/inputTelefone"
                            style="@style/Widget.Material3.TextInputLayout.FilledBox"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:layout_marginBottom="15dp"
                            android:hint="Telefone"
                            app:boxBackgroundColor="?attr/colorSurfaceVariant"
                            app:boxStrokeWidth="0dp"
                            app:boxStrokeWidthFocused="0dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etTelefone"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="?attr/colorOnSurface"
                                android:background="@drawable/bg_tag_status"
                                android:inputType="phone" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/inputEmail"
                        style="@style/Widget.Material3.TextInputLayout.FilledBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="15dp"
                        android:hint="Email"
                        app:boxBackgroundColor="?attr/colorSurfaceVariant"
                        app:boxStrokeWidth="0dp"
                        app:boxStrokeWidthFocused="0dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="?attr/colorOnSurface"
                            android:background="@drawable/bg_tag_status"
                            android:inputType="text" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/btnAdicionarFoto"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_tag_status"
                        android:backgroundTint="?attr/colorSurfaceVariant"
                        android:layout_marginBottom="15dp">

                        <ImageView
                            android:id="@+id/iv_icone_perfil"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/outline_person_24"
                            android:scaleType="centerCrop"
                            android:clipToOutline="true"
                            android:background="@drawable/bg_tag_status"
                            android:backgroundTint="?attr/colorIconBackground"
                            android:padding="8dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />

                        <TextView
                            android:id="@+id/tv_titulo_foto"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="Foto do Visitante"
                            android:textStyle="bold"
                            android:textColor="?attr/colorAccent"
                            android:textSize="16sp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/iv_icone_perfil"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toTopOf="@+id/tv_subtitulo_foto" />

                        <TextView
                            android:id="@+id/tv_subtitulo_foto"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Clique para capturar ou selecionar"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="13sp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/iv_icone_perfil"
                            app:layout_constraintStart_toStartOf="@+id/tv_titulo_foto"
                            app:layout_constraintTop_toBottomOf="@+id/tv_titulo_foto"
                            app:layout_constraintBottom_toBottomOf="parent" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/tituloDadosInformacionaisForms"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginBottom="15dp"
                        >

                        <ImageView
                            android:id="@+id/iconDadosInformacionaisForms"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/outline_home_24"
                            android:scaleType="centerCrop"
                            android:clipToOutline="true"
                            android:background="@drawable/bg_icon"
                            android:backgroundTint="?attr/colorIconBackground"
                            android:padding="8dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />

                        <TextView
                            android:id="@+id/txtDadosInformacionaisForms"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginStart="16dp"
                            android:text="Dados Informacionais"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="25sp"
                            android:gravity="center_vertical"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/iconDadosInformacionaisForms"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"/>


                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorSurfaceVariant"
                        android:layout_marginBottom="24dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/tituloDadosInformacionaisForms" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/dropdownEmpresa"
                        style="@style/Widget.Material3.TextInputLayout.FilledBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Empresa"
                        android:layout_marginBottom="15dp">

                        <AutoCompleteTextView
                            android:id="@+id/autoCompleteEmpresa"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:focusable="false"
                            android:inputType="none"
                            android:textColor="?attr/colorOnSurface"
                            android:padding="16dp"
                            android:background="@drawable/bg_tag_status"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/dropdownSetorResponsavel"
                        style="@style/Widget.Material3.TextInputLayout.FilledBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Setor responsavel"
                        android:layout_marginBottom="15dp">

                        <AutoCompleteTextView
                            android:id="@+id/autoCompleteSetorResponsavel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:focusable="false"
                            android:inputType="none"
                            android:textColor="?attr/colorOnSurface"
                            android:padding="16dp"
                            android:background="@drawable/bg_tag_status"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/dropdownMotivoDeVisita"
                        style="@style/Widget.Material3.TextInputLayout.FilledBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Motivo de visita"
                        android:layout_marginBottom="15dp">

                        <AutoCompleteTextView
                            android:id="@+id/autoCompleteMotivoDeVisita"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:focusable="false"
                            android:inputType="none"
                            android:textColor="?attr/colorOnSurface"
                            android:padding="16dp"
                            android:background="@drawable/bg_tag_status"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/btnAdicionarCracha"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_tag_status"
                        android:backgroundTint="?attr/colorSurfaceVariant">

                        <ImageView
                            android:id="@+id/iv_icone_cracha"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/outline_badge_24"
                            android:background="@drawable/bg_tag_status"
                            android:backgroundTint="?attr/colorIconBackground"
                            android:padding="8dp"
                            app:tint="?attr/colorAccent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />

                        <TextView
                            android:id="@+id/tv_titulo_cracha"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="Vincular Crachá"
                            android:textStyle="bold"
                            android:textColor="?attr/colorAccent"
                            android:textSize="16sp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/iv_icone_cracha"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toTopOf="@+id/tv_subtitulo_cracha" />

                        <TextView
                            android:id="@+id/tv_subtitulo_cracha"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="Aproxime o crachá do leitor RFID"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:alpha="0.7"
                            android:textSize="13sp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/iv_icone_cracha"
                            app:layout_constraintTop_toBottomOf="@+id/tv_titulo_cracha"
                            app:layout_constraintBottom_toBottomOf="parent" />

                    </androidx.constraintlayout.widget.ConstraintLayout>


                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">



                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Setores Permitidos"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="14sp"
                        android:layout_marginBottom="12dp" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupSetores"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:selectionRequired="true"
                        app:chipSpacingHorizontal="8dp"
                        app:chipSpacingVertical="4dp"
                        android:layout_marginBottom="8dp" />


                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="24dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFinalizarCheckIn"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="Finalizar Registro"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="12dp"
                    android:backgroundTint="?attr/colorPrimary"
                    android:textColor="?attr/colorOnPrimary"
                    app:elevation="4dp" />

                <ProgressBar
                    android:id="@+id/progressBarCheckIn"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:visibility="gone"
                    android:indeterminateTint="?attr/colorOnPrimary" />
            </FrameLayout>

            <!-- Spacer para não esconder conteúdo atrás do BottomNav flutuante -->
            <View
                android:layout_width="match_parent"
                android:layout_height="40dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
