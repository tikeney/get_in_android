<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="?attr/colorSurface"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <View
            android:id="@+id/shimmer_foto"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_tag_status"
            android:backgroundTint="#E0E0E0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/shimmer_nome"
            android:layout_width="150dp"
            android:layout_height="16dp"
            android:layout_marginStart="16dp"
            android:background="#E0E0E0"
            app:layout_constraintStart_toEndOf="@+id/shimmer_foto"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/shimmer_empresa"
            android:layout_width="100dp"
            android:layout_height="14dp"
            android:layout_marginTop="8dp"
            android:background="#E0E0E0"
            app:layout_constraintStart_toStartOf="@+id/shimmer_nome"
            app:layout_constraintTop_toBottomOf="@+id/shimmer_nome" />

        <View
            android:id="@+id/shimmer_tag"
            android:layout_width="80dp"
            android:layout_height="24dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_tag_status"
            android:backgroundTint="#E0E0E0"
            app:layout_constraintStart_toStartOf="@+id/shimmer_nome"
            app:layout_constraintTop_toBottomOf="@+id/shimmer_empresa" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
