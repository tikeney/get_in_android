<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".LoginActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/ConstHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/ConstForm"
        android:background="@color/secundary">

        <ImageView
            android:id="@+id/logo"
            android:layout_width="wrap_content"
            android:layout_height="75dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:src="@drawable/ic_launcher_background"/>

        <TextView
            android:id="@+id/txtTituloHeader"
            android:layout_width="270dp"
            android:layout_height="wrap_content"
            android:text="Bem-vindo de volta"
            android:textSize="38dp"
            android:textStyle="bold"
            android:textColor="@color/white"
            app:layout_constraintTop_toBottomOf="@+id/logo"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="10dp"/>

        <TextView
            android:id="@+id/txtSubTituloHeader"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:text="Acesse o painel de controle"
            android:textSize="16dp"
            android:textColor="@color/accent"
            app:layout_constraintTop_toBottomOf="@+id/txtTituloHeader"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="10dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/ConstForm"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/white"
        android:paddingTop="50dp"
        android:paddingHorizontal="40dp"
        app:layout_constraintTop_toBottomOf="@+id/ConstHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/txtUsuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Usuário"
            android:textSize="16dp"
            android:textColor="@color/black"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" /><!-- text: Usuário-->

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/inputUsuario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@+id/txtUsuario"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="5dp"
            app:boxCornerRadiusBottomEnd="20dp"
            app:boxCornerRadiusBottomStart="20dp"
            app:boxCornerRadiusTopEnd="20dp"
            app:boxCornerRadiusTopStart="20dp"
            app:hintEnabled="false"
            app:boxStrokeColor="@color/secundary"
            app:boxBackgroundColor="@color/InputLoginBackground">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etUsuario"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:hint="Digite seu usuário"
                android:textColorHint="@color/InputLoginHint"
                android:textColor="@color/secundary" />

        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/txtSenha"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Senha"
            android:textSize="16dp"
            android:textColor="@color/black"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@+id/inputUsuario"
            app:layout_constraintStart_toStartOf="parent" /><!-- text: Senha-->

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/inputSenha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@+id/txtSenha"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="5dp"
            app:boxCornerRadiusBottomEnd="20dp"
            app:boxCornerRadiusBottomStart="20dp"
            app:boxCornerRadiusTopEnd="20dp"
            app:boxCornerRadiusTopStart="20dp"
            app:hintEnabled="false"
            app:boxStrokeColor="@color/secundary"
            app:boxBackgroundColor="@color/InputLoginBackground"
            app:endIconMode="password_toggle"
            app:endIconTint="@color/secundary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSenha"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:hint="Senha"
                android:textColorHint="@color/InputLoginHint"
                android:textColor="@color/secundary"
                android:inputType="textPassword" />

        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            app:layout_constraintTop_toBottomOf="@+id/inputSenha"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="40dp"
            app:cornerRadius="20dp"
            android:text="Entrar"
            android:textSize="20dp"
            android:textColor="@color/white"
            android:backgroundTint="@color/secundary"/>

        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="@color/accent"
            android:layout_marginVertical="40dp"
            android:layout_marginEnd="10dp"
            app:layout_constraintTop_toBottomOf="@+id/btnLogin"
            app:layout_constraintEnd_toStartOf="@+id/txtFormasDeLogin"/>

        <TextView
            android:id="@+id/txtFormasDeLogin"
            android:layout_width="wrap_content"
            android:layout_height="20dp"
            android:text="ou entre com"
            android:textColor="@color/accent"
            android:layout_marginVertical="30dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnLogin"/>

        <View
            android:id="@+id/divider2"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="@color/accent"
            android:layout_marginVertical="40dp"
            android:layout_marginStart="10dp"
            app:layout_constraintTop_toBottomOf="@+id/btnLogin"
            app:layout_constraintStart_toEndOf="@+id/txtFormasDeLogin"/>

        <Button
            android:id="@+id/btnLoginRFID"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            app:layout_constraintTop_toBottomOf="@+id/txtFormasDeLogin"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="40dp"
            app:cornerRadius="20dp"
            android:text="Entrar com crachá"
            android:textSize="20dp"
            android:textColor="@color/secundary"
            android:backgroundTint="@color/accent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>