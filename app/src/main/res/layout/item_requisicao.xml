<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="?android:attr/windowBackground"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/divider_color"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Ícone/Avatar -->
        <View
            android:id="@+id/viewIconBg"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/fundo_cracha"
            android:backgroundTint="@color/icon_bg_light"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/imgIcone"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/outline_person_24"
            app:layout_constraintBottom_toBottomOf="@id/viewIconBg"
            app:layout_constraintEnd_toEndOf="@id/viewIconBg"
            app:layout_constraintStart_toStartOf="@id/viewIconBg"
            app:layout_constraintTop_toTopOf="@id/viewIconBg"
            app:tint="@color/gray_text" />

        <!-- Nome e Documento -->
        <TextView
            android:id="@+id/txtNome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Nome do Usuário"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/txtDia"
            app:layout_constraintStart_toEndOf="@id/viewIconBg"
            app:layout_constraintTop_toTopOf="@id/viewIconBg" />

        <TextView
            android:id="@+id/txtDocumento"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="000.000.000-00"
            android:textColor="@color/gray_text"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="@id/txtNome"
            app:layout_constraintStart_toStartOf="@id/txtNome"
            app:layout_constraintTop_toBottomOf="@id/txtNome" />

        <!-- Data e Hora -->
        <TextView
            android:id="@+id/txtDia"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="02/05"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/txtNome" />

        <TextView
            android:id="@+id/txtHorario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="@color/gray_text"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txtDia" />

        <!-- ChipGroup (Pills) -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:chipSpacingHorizontal="8dp"
            app:chipSpacingVertical="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/viewIconBg">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipEmpresa"
                style="@style/Widget.Material3.Chip.Assist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Empresa"
                app:chipBackgroundColor="@color/pill_bg_blue"
                app:chipCornerRadius="12dp"
                app:chipStrokeWidth="0dp"
                android:textColor="@color/secundary"
                android:textSize="11sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipMotivo"
                style="@style/Widget.Material3.Chip.Assist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tipo"
                app:chipBackgroundColor="@color/pill_bg_blue"
                app:chipCornerRadius="12dp"
                app:chipStrokeWidth="0dp"
                android:textColor="@color/secundary"
                android:textSize="11sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSetor"
                style="@style/Widget.Material3.Chip.Assist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Setor"
                app:chipBackgroundColor="@color/pill_bg_blue"
                app:chipCornerRadius="12dp"
                app:chipStrokeWidth="0dp"
                android:textColor="@color/secundary"
                android:textSize="11sp" />

        </com.google.android.material.chip.ChipGroup>

        <!-- Bloco de Descrição -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/bgDescricao"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/InputLoginBackground"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/chipGroup">

            <TextView
                android:id="@+id/txtDescricao"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:text="Descrição detalhada aqui..."
                android:textColor="@color/gray_text"
                android:textSize="12sp" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Divisor -->
        <View
            android:id="@+id/dividerItem"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="@color/divider_color"
            app:layout_constraintTop_toBottomOf="@id/bgDescricao" />

        <!-- Botões de Ação -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/dividerItem">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNegar"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="Negar"
                android:textAllCaps="false"
                android:textColor="?android:attr/textColorPrimary"
                app:strokeColor="@color/divider_color" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAceitar"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="Aprovar"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:backgroundTint="@color/secundary" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
