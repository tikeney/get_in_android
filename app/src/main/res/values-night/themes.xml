<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Get_In" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary Brand Color -->
        <item name="colorPrimary">@color/brand_blue</item>
        <item name="colorOnPrimary">@color/pure_white</item>
        <item name="colorPrimaryContainer">@color/brand_blue_dark</item>
        <item name="colorOnPrimaryContainer">@color/off_white</item>

        <!-- Secondary / Accent -->
        <item name="colorSecondary">@color/brand_blue_light</item>
        <item name="colorOnSecondary">@color/pure_white</item>

        <!-- Background and Surfaces -->
        <item name="android:windowBackground">@color/dark_bg</item>
        <item name="colorSurface">@color/dark_surface</item>
        <item name="colorOnSurface">@color/dark_text_primary</item>
        <item name="colorOnSurfaceVariant">@color/dark_text_secondary</item>
        <item name="colorOutline">@color/dark_divider</item>

        <!-- Status Bar & Navigation Bar -->
        <item name="android:statusBarColor">@color/pure_black</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
